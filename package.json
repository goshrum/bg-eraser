    "test:watch": "vitest",
    "smoke": "node --experimental-vm-modules scripts/smoke.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
