{
  "name": "bg-eraser",
  "private": true,
  "version": "1.0.0",
  "description": "In-browser AI background remover. 100% on-device, no upload, no API key.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
